# ==============================================================
# Enrollify Outreach — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.
# ==============================================================

# --- Anthropic API ---
# Get from: https://console.anthropic.com/settings/keys
# Requires ~$5-10 top-up to start. Does NOT use your Pro subscription.
ANTHROPIC_API_KEY=

# --- Google Cloud: Places API ---
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your Google Cloud project.
# Free $200/month credit auto-applied. Restrict key to Places API + your IP.
GOOGLE_PLACES_API_KEY=

# --- Google Cloud: Sheets API ---
# Service account JSON file. See docs/setup_google.md
GOOGLE_SHEETS_CREDENTIALS_PATH=./config/google-service-account.json
GOOGLE_SHEET_ID=

# --- Zoho Mail ---
# Create free account at https://www.zoho.com/mail/
# Use app-specific password (NOT your login password).
# Generate at: https://accounts.zoho.com/home#security/app_password
ZOHO_EMAIL=ketan@enrollifyapp.com
ZOHO_APP_PASSWORD=
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_PORT=993
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465

# --- Pushover (Phase 6) ---
# One-time $5 app purchase. Get keys from: https://pushover.net/
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# --- Project config ---
DEFAULT_DAILY_EMAIL_CAP=20
WORKING_HOURS_START=9
WORKING_HOURS_END=17
TIMEZONE=America/Los_Angeles
HOME_ZIP=90045
